classDiagram
    class User {
        +int id
        +string name
        +string email
        +login()
        +placeOrder()
    }

    class Product {
        +int id
        +string name
        +decimal price
        +bool inStock
    }

    class Order {
        +int id
        +string status
        +decimal total
        +submit()
        +cancel()
    }

    User "1" --> "0..*" Order : places
    Order "1" --> "1..*" Product : contains
